# Supabase (public keys only) — use VITE_ prefix (Vite app, not Next.js)
# Cloud save/sync only runs on production builds (Vercel, Netlify). Local npm run dev uses browser storage.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
